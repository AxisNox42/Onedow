# 기본: Git 이 자동 정규화 (저장소에는 LF 로 저장)
* text=auto

# ── 셸/CI/빌드 스크립트는 반드시 LF ──
#   macOS/Linux 러너에서 CRLF(\r) 로 인한 스크립트 오류 방지
*.sh            text eol=lf
*.yml           text eol=lf
*.yaml          text eol=lf
CMakeLists.txt  text eol=lf

# ── Windows 전용 프로젝트 파일은 CRLF 유지 ──
*.vcxproj         text eol=crlf
*.vcxproj.filters text eol=crlf
*.sln             text eol=crlf
*.rc              text eol=crlf

# ── 바이너리 (변환 금지) ──
*.ttf binary
*.otf binary
*.png binary
*.jpg binary
*.jpeg binary
*.ico binary
*.lib binary
